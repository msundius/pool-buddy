# Pool Buddy configuration — single source of truth for basic settings.
#
# Copy this file to `.env` and edit the values for your deployment.
# Both the Node server (via dotenv) and Docker Compose (native ${VAR}
# interpolation) read these values, so each setting lives in one place.

# --- Backend ---
# Port the backend listens on, and the Docker host port it is published on.
PORT=3030
NODE_ENV=production

# --- Database (bundled Postgres container) ---
POSTGRES_DB=poolbuddy
POSTGRES_USER=poolbuddy
POSTGRES_PASSWORD=change-me-local-only
# Host port the Postgres container is published on.
POSTGRES_PORT=5432

# Connection string used by the backend.
# Under Docker Compose this is built automatically from the POSTGRES_* values
# above. For local (non-Docker) runs, point it at your reachable Postgres.
DATABASE_URL=postgres://poolbuddy:change-me-local-only@localhost:5432/poolbuddy

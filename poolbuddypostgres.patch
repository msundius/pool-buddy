new file mode 100644
index 0000000..6b88a2b
--- /dev/null
+++ b/docker-compose.yml
@@ -0,0 +1,35 @@
+# Pool Buddy — local self-hosted stack.
+# Edit the values below (especially POSTGRES_PASSWORD) before deploying.
+services:
+  db:
+    image: postgres:16-alpine
+    restart: unless-stopped
+    environment:
+      POSTGRES_DB: poolbuddy
+      POSTGRES_USER: poolbuddy
+      POSTGRES_PASSWORD: change-me-local-only
+    volumes:
+      - pooldata:/var/lib/postgresql/data
+    ports:
+      - "5432:5432"
+    healthcheck:
+      test: ["CMD-SHELL", "pg_isready -U poolbuddy"]
+      interval: 5s
+      timeout: 5s
+      retries: 5
+
+  backend:
+    build: .
+    restart: unless-stopped
+    environment:
+      PORT: 3000
+      NODE_ENV: production
+      DATABASE_URL: postgres://poolbuddy:change-me-local-only@db:5432/poolbuddy
+    ports:
+      - "3000:3000"
+    depends_on:
+      db:
+        condition: service_healthy
+
+volumes:
+  pooldata:
